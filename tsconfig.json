{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist",
        "module": "commonjs",
        "target": "es2020",
        "types": ["node"],
        "lib": ["es2020"],
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "noUncheckedIndexedAccess": false,
        "exactOptionalPropertyTypes": false,
        "strict": true,
        "isolatedModules": true,
        "skipLibCheck": true
    }
}
