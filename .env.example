# Server
PORT=3000

# MongoDB connection (if you need run the application locally without docker, use the following URI pointing to your local MongoDB instance)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=bakery

# JWT auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1
AUTH_USERNAME=admin
AUTH_PASSWORD=change_this_password

# Baking configuration
BAKE_TIME_SCALE_MS_PER_MIN=1000
BAKE_RECONCILE_INTERVAL_MS=1000

# Oven configuration
OVEN_COUNT=2
SLOTS_PER_OVEN=3

# Seed default menu items on startup when menu is empty
SEED_MENU_ON_START=true
